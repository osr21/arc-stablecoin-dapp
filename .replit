modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_CONDITIONAL_ESCROW_ADDRESS = "0x34733fbbC101F2244Df03508170893013528004e"
VITE_PAYROLL_VESTING_ADDRESS = "0x113F24249b0521d7288E52D12AE869d5903E6143"
VITE_CROSSCHAIN_ESCROW_ADDRESS = "0x1e0AaD16aaBFe906987D70A00783E9ab67954aFF"
VITE_ARC_RPC_URL = "https://rpc.testnet.arc.network"
VITE_ARC_CHAIN_ID = "5042002"
VITE_USDC_ADDRESS = "0x3600000000000000000000000000000000000000"
VITE_EURC_ADDRESS = "0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a"
