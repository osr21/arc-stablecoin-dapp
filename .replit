modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 22967
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
VITE_CONDITIONAL_ESCROW_ADDRESS = "0xe64a01283af91a601ebf5a86efe36312783330e8"
VITE_PAYROLL_VESTING_ADDRESS = "0xdc14d0a5233173776fc4ea1007251afb174d67e8"
VITE_CROSSCHAIN_ESCROW_ADDRESS = "0x54d8ecd5de6e1ead23a1f00ec8d8acad495f4865"
VITE_ARC_RPC_URL = "https://rpc.testnet.arc.network"
VITE_ARC_CHAIN_ID = "5042002"
VITE_USDC_ADDRESS = "0x3600000000000000000000000000000000000000"
VITE_EURC_ADDRESS = "0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a"
