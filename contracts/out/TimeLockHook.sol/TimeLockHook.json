\"},{\"inputs\":[],\"name\":\"AlreadyClaimed\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"NoUSDCReceived\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"NotRecipient\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"RelayFailed\",\"type\":\"error\"},{\"inputs\":[],\"name\":\"ReleaseNotFound\",\"type\":\"error\"},{\"inputs\":[{\"internalType\":\"uint256\",\"name\":\"unlockTime\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"current\",\"type\":\"uint256\"}],\"name\":\"StillLocked\",\"type\":\"error\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"releaseId\",\"type\":\"bytes32\"},{\"indexed\":true,\"internalType\":\"address\",\"name\":\"recipient\",\"type\":\"address\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"unlockTime\",\"type\":\"uint256\"}],\"name\":\"ReleaseScheduled\",\"type\":\"event\"},{\"anonymous\":false,\"inputs\":[{\"indexed\":true,\"internalType\":\"bytes32\",\"name\":\"releaseId\",\"type\":\"bytes32\"},{\"indexed\":true,\"internalType\":\"address\",\"name\":\"recipient\",\"type\":\"address\"},{\"indexed\":false,\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"}],\"name\":\"Released\",\"type\":\"event\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"releaseId\",\"type\":\"bytes32\"}],\"name\":\"claim\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"releaseId\",\"type\":\"bytes32\"}],\"name\":\"getRelease\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"recipient\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"unlockTime\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"claimed\",\"type\":\"bool\"},{\"internalType\":\"bool\",\"name\":\"claimable\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"messageTransmitter\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"owner\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes32\",\"name\":\"\",\"type\":\"bytes32\"}],\"name\":\"pendingReleases\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"recipient\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"amount\",\"type\":\"uint256\"},{\"internalType\":\"uint256\",\"name\":\"unlockTime\",\"type\":\"uint256\"},{\"internalType\":\"bool\",\"name\":\"claimed\",\"type\":\"bool\"}],\"stateMutability\":\"view\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"bytes\",\"name\":\"message\",\"type\":\"bytes\"},{\"internalType\":\"bytes\",\"name\":\"attestation\",\"type\":\"bytes\"},{\"internalType\":\"address\",\"name\":\"finalRecipient\",\"type\":\"address\"},{\"internalType\":\"uint256\",\"name\":\"unlockTimestamp\",\"type\":\"uint256\"}],\"name\":\"relay\",\"outputs\":[{\"internalType\":\"bytes32\",\"name\":\"releaseId\",\"type\":\"bytes32\"}],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[],\"name\":\"usdc\",\"outputs\":[{\"internalType\":\"address\",\"name\":\"\",\"type\":\"address\"}],\"stateMutability\":\"view\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{\"claim(bytes32)\":{\"params\":{\"releaseId\":\"The ID emitted in the ReleaseScheduled event during relay().\"}},\"relay(bytes,bytes,address,uint256)\":{\"details\":\"SECURITY NOTE (testnet): `finalRecipient` and `unlockTimestamp` are      caller-supplied and not verified against the hookData embedded in the      CCTP message. A malicious relayer could supply an arbitrary recipient      or a past unlock time. For production, parse and verify these values      from the BurnMessageV2 hookData in `message`.      In this demo the intended relayer is always the finalRecipient themselves.\"}},\"title\":\"TimeLockHook (v6 \\u2014 self-relay design)\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"claim(bytes32)\":{\"notice\":\"Claim time-locked USDC after the unlock timestamp.\"},\"messageTransmitter()\":{\"notice\":\"MessageTransmitterV2 on this chain \\u2014 called internally by relay().\"}},\"notice\":\"CCTP v2 time-lock contract deployed on destination chains (e.g. Ethereum Sepolia). \\u250c\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2510 \\u2502  FLOW                                                                       \\u2502 \\u2502                                                                             \\u2502 \\u2502  1. Sender on Arc calls CrosschainEscrow.initiateConditionalTransfer with:  \\u2502 \\u2502       recipient  = address(TimeLockHook)  \\u2190 this contract on dest chain    \\u2502 \\u2502       hookData   = abi.encode(finalRecipient, unlockTimestamp, amount)      \\u2502 \\u2502                                                                             \\u2502 \\u2502  2. Circle attests the burn message.                                        \\u2502 \\u2502                                                                             \\u2502 \\u2502  3. Anyone calls THIS contract's relay():                                   \\u2502 \\u2502       TimeLockHook.relay(message, attestation, finalRecipient, unlockTs)    \\u2502 \\u2502     \\u2192 internally calls MessageTransmitterV2.receiveMessage()               \\u2502 \\u2502     \\u2192 USDC minted to address(this) [since mintRecipient = TimeLockHook]    \\u2502 \\u2502     \\u2192 PendingRelease stored with a unique nonce-based releaseId             \\u2502 \\u2502     \\u2192 ReleaseScheduled(releaseId, ...) emitted                             \\u2502 \\u2502                                                                             \\u2502 \\u2502  4. After unlockTimestamp, finalRecipient calls:                            \\u2502 \\u2502       TimeLockHook.claim(releaseId)                                         \\u2502 \\u2502     \\u2192 USDC transferred to finalRecipient                                   \\u2502 \\u2514\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2500\\u2518 KEY DESIGN INSIGHT (v6 vs previous versions):   Circle's CCTP v2 hook mechanism does NOT automatically call handleReceiveMessage   on the mintRecipient. USDC is simply ERC-20 transferred to mintRecipient, and hooks   only run if someone calls a Circle CCTPHookWrapper.relay(). We avoid that complexity   by making TimeLockHook itself the relay entrypoint: it calls receiveMessage() and   registers the pending release atomically. MessageTransmitterV2 is deployed via CREATE2 at the same address on all CCTP v2 chains:   0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275 releaseId is deterministic per relay() call:   keccak256(abi.encode(block.chainid, address(this), relayNonce++))   \\u2014 unique per chain, per contract, per relay invocation.   Frontend reads it from the ReleaseScheduled event emitted by relay().\",\"version\":1}},\"settings\":{\"compilationTarget\":{\"src/TimeLockHook.sol\":\"TimeLockHook\"},\"evmVersion\":\"paris\",\"libraries\":{},\"metadata\":{\"bytecodeHash\":\"ipfs\"},\"optimizer\":{\"enabled\":true,\"runs\":200},\"remappings\":[\":forge-std/=lib/forge-std/src/\"],\"viaIR\":true},\"sources\":{\"src/IERC20.sol\":{\"keccak256\":\"0x9ac7895c65853fb5b98f95d1f967e313f4a2a823a9a70409d73b48f23f1c7aa8\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://a24ccfc240c86caacbfe65266375f036381985555d8176b98cad4a9f98d23b5e\",\"dweb:/ipfs/Qmf2WnEs4CVK9pmgQ4SAhtkZtg6qKhViY7G5gteJfJeeyy\"]},\"src/TimeLockHook.sol\":{\"keccak256\":\"0x3d22ccc4d3e9e162ede730dbe581777642d8732e16546c740efe6532b383723b\",\"license\":\"MIT\",\"urls\":[\"bzz-raw://7992086417cf0ca048918dd72856b2f3569f2b83528044e2207e6ad97cca360a\",\"dweb:/ipfs/QmXgC7pGDBDQrXCncQPpeSyKYsWereHYAnQGcWKsf9PmAQ\"]}},\"version\":1}","metadata":{"compiler":{"version":"0.8.20+commit.a1b79de6"},"language":"Solidity","output":{"abi":[{"inputs":[{"internalType":"address","name":"_messageTransmitter","type":"address"},{"internalType":"address","name":"_usdc","type":"address"}],"stateMutability":"nonpayable","type":"constructor"},{"inputs":[],"type":"error","name":"AlreadyClaimed"},{"inputs":[],"type":"error","name":"NoUSDCReceived"},{"inputs":[],"type":"error","name":"NotRecipient"},{"inputs":[],"type":"error","name":"RelayFailed"},{"inputs":[],"type":"error","name":"ReleaseNotFound"},{"inputs":[{"internalType":"uint256","name":"unlockTime","type":"uint256"},{"internalType":"uint256","name":"current","type":"uint256"}],"type":"error","name":"StillLocked"},{"inputs":[{"internalType":"bytes32","name":"releaseId","type":"bytes32","indexed":true},{"internalType":"address","name":"recipient","type":"address","indexed":true},{"internalType":"uint256","name":"amount","type":"uin